{
  "meta": {
    "name": "SheBattle Light",
    "base": "light",
    "description": "Tema claro com rosa neon, azul ciano e branco luxuoso"
  },

  "colors": {
    "background":    "#f7f4ff",
    "surface":       "#ffffff",
    "surface_2":     "#999999",

    "primary":       "#ff2e9e",
    "primary_hover": "#ff5bb5",

    "secondary":     "#00cfe8",
    "accent":        "#333",

    "text":          "#24163a",
    "text_muted":    "#6d5c91",
    "text_disabled": "#b6a7cf",

    "border":        "#dccdf7",
    "border_focus":  "#ff2e9e",

    "success":       "#00cfe8",
    "warning":       "#ff9e2e",
    "danger":        "#ff3366",
    "info":          "#9b5de5",

    "pink_glow":     "#ff69b4",
    "cyan_glow":     "#00e5ff"
  },

  "typography": {
    "font_family":      "Inter, system-ui, sans-serif",
    "font_family_mono": "JetBrains Mono, monospace",

    "size_xs":          10,
    "size_sm":          12,
    "size_base":        14,
    "size_subtitle":    17,
    "size_title":       25,
    "size_display":     42,

    "weight_normal":    400,
    "weight_medium":    500,
    "weight_bold":      700,

    "line_height":      1.65
  },

  "effects": {
    "hover_y": "-4px",

    "glow_pink":  "0 0 18px rgba(255,46,158,0.35)",
    "glow_cyan":  "0 0 18px rgba(0,240,255,0.28)",
    "glow_white": "0 0 20px rgba(255,255,255,0.9)"
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "14px",
    "lg": "24px",
    "xl": "42px"
  },

  "borders": {
    "width":       "1px",

    "radius_sm":   "8px",
    "radius_md":   "14px",
    "radius_lg":   "20px",
    "radius_full": "9999px",

    "shadow_sm":   "0 2px 10px rgba(255,46,158,0.10)",
    "shadow_md":   "0 8px 28px rgba(0,240,255,0.12)",
    "shadow_lg":   "0 14px 48px rgba(255,46,158,0.16)"
  },

  "chart": {
    "height":      420,

    "colorscale": [
      "#ff2e9e",
      "#00cfe8",
      "#ffffff",
      "#9b5de5",
      "#ff8ac2"
    ],

    "grid_color":  "rgba(36,22,58,0.08)",
    "font_color":  "#4c3a70",

    "plotly": {
      "bg":      "transparent",
      "plot_bg": "transparent"
    },

    "echarts": {
      "tooltip_bg":       "rgba(255,255,255,0.96)",
      "tooltip_border":   "rgba(255,46,158,0.25)",
      "tooltip_text":     "#24163a",

      "axis_line_color":  "rgba(0,207,232,0.22)",
      "axis_label_color": "rgba(36,22,58,0.55)",

      "split_line_color": "rgba(255,46,158,0.08)",

      "glow_blur":        8,

      "area_opacity_top": 0.35,
      "area_opacity_base": 0.04
    }
  }
}