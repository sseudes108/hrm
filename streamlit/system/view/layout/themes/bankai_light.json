{
  "meta": {
    "name": "Bankai Light",
    "base": "light",
    "description": "Versão clara inspirada na Bankai do Ichigo — branco espiritual, cinzas metálicos, laranja intenso e vermelho profundo."
  },

  "icons": {
    "toggle": "lightbulb-off"
  },


  "colors": {
    "background":    "#f5f5f7",
    "surface":       "#ffffff",
    "surface_2":     "#ebedf2",

    "primary":       "#ff6a00",
    "primary_hover": "#ff8533",

    "secondary":     "#4b5563",
    "accent":        "#b31217",

    "text":          "#111318",
    "text_muted":    "#6b7280",
    "text_disabled": "#9ca3af",

    "border":        "#d4d4d8",
    "border_focus":  "#ff6a00",

    "success":       "#16a34a",
    "warning":       "#d97706",
    "danger":        "#dc2626",
    "info":          "#52525b"
  },

  "typography": {
    "font_family":      "Inter, sans-serif",
    "font_family_mono": "JetBrains Mono, monospace",

    "size_xs":          10,
    "size_sm":          12,
    "size_base":        14,
    "size_subtitle":    18,
    "size_title":       26,
    "size_display":     44,

    "weight_normal":    400,
    "weight_medium":    500,
    "weight_bold":      700,

    "line_height":      1.6
  },

  "effects": {
    "hover_y": "-2px",

    "glow_primary": "0 0 16px rgba(255,106,0,0.16)",
    "glow_danger":  "0 0 12px rgba(179,18,23,0.16)",

    "glass_blur": "10px",

    "gradient_primary":
      "linear-gradient(135deg, rgba(255,106,0,1) 0%, rgba(179,18,23,0.92) 100%)"
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "14px",
    "lg": "24px",
    "xl": "40px"
  },

  "borders": {
    "width":       "1px",

    "radius_sm":   "4px",
    "radius_md":   "10px",
    "radius_lg":   "14px",
    "radius_full": "9999px",

    "shadow_sm":   "0 1px 4px rgba(0,0,0,0.06)",
    "shadow_md":   "0 4px 12px rgba(0,0,0,0.10)",
    "shadow_lg":   "0 10px 30px rgba(0,0,0,0.14)"
  },

  "chart": {
    "height": 400,

    "colorscale": [
      "#ff6a00",
      "#b31217",
      "#6b7280",
      "#d1d5db",
      "#111318"
    ],

    "grid_color": "rgba(0,0,0,0.06)",
    "font_color": "#6b7280",

    "plotly": {
      "bg":      "transparent",
      "plot_bg": "transparent"
    },

    "echarts": {
      "tooltip_bg":       "rgba(255,255,255,0.96)",
      "tooltip_border":   "rgba(255,106,0,0.22)",
      "tooltip_text":     "#111318",

      "axis_line_color":  "rgba(0,0,0,0.14)",
      "axis_label_color": "rgba(0,0,0,0.5)",

      "split_line_color": "rgba(0,0,0,0.05)",

      "glow_blur":        10,

      "area_opacity_top": 0.28,
      "area_opacity_base": 0.02
    }
  }
}