    "surface_overlay": {
      "enabled": true,
      "border_gradient": "linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.6) 30%, rgba(15,118,110,0) 50%, rgba(15,118,110,0.6) 70%, #0f766e 100%)",
