{
  "meta": {
    "name": "Lakshmi Light - Divine Palace",
    "base": "light",
    "description": "Tema claro inspirado no Palácio da Deusa Lakshmi — opulência védica com fundos de marfim, detalhes em ouro e cobre, e textos em índigo profundo com acabamento em vidro polido."
  },

  "layout": {
    "header_height": "81px",
    "icon_size": "66px"
  },

  "icons": {
    "toggle": "sun"
  },

  "colors": {
    "background":    "#fdfbf7",
    "surface":       "#ffffff",
    "surface_2":     "#f4f1ea",

    "primary":       "#c5a059",
    "primary_hover": "#d5b472",

    "secondary":     "#b87333",
    "accent":        "#1e1b4b",

    "text":          "#1e1b4b",
    "text_muted":    "#64748b",
    "text_disabled": "#94a3b8",

    "border":        "#e5e0d8",
    "border_focus":  "#c5a059",

    "success":       "#10b981",
    "warning":       "#f59e0b",
    "danger":        "#be123c",
    "info":          "#0f172a",

    "overlay_app": "rgba(253,251,247,0.15)"
  },

  "typography": {
    "font_family":      "Inter, sans-serif",
    "font_family_mono": "JetBrains Mono, monospace",
    "size_xs":          10,
    "size_sm":          12,
    "size_base":        14,
    "size_subtitle":    18,
    "size_title":       26,
    "size_display":     44,
    "weight_normal":    400,
    "weight_medium":    500,
    "weight_bold":      700,
    "line_height":      1.6
  },

  "effects": {
    "hover_y": "-2px",
    "backdrop_blur": "27px",

    "glow_primary": "0 0 16px rgba(197,160,89,0.25)",
    "glow_danger":  "0 0 12px rgba(190,18,60,0.15)",

    "gradient_primary": "linear-gradient(135deg, #c5a059 0%, #b87333 100%)",
    "gradient_surface": "linear-gradient(180deg, rgba(245,240,232,0.55) 0%, rgba(253,251,247,0.60) 100%)",

    "surface_overlay": {
      "enabled": true,
      "border_gradient": "linear-gradient(135deg, rgba(255,255,255,0.75) 0%, rgba(255,255,255,0.75) 40%, rgba(197,160,89,0.15) 100%, rgba(255,255,255,0.75) 100%)",
      "inner_shadow": "inset 0 1px 0px rgba(255,255,255,0.85), inset 0 -1px 12px rgba(197,160,89,0.05)"
    }
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "14px",
    "lg": "24px",
    "xl": "40px"
  },

  "borders": {
      "width":       "1px",
      "radius_sm":   "4px",
      "radius_md":   "8px",
      "radius_lg":   "12px",
      "radius_full": "9999px",
      "shadow_sm":   "0 1px 4px rgba(30,27,75,0.04)",
      "shadow_md":   "0 4px 12px rgba(30,27,75,0.06)",
      "shadow_lg":   "0 8px 24px rgba(30,27,75,0.08)"
  },

  "chart": {
    "height": 400,
    "grid_color": "rgba(30,27,75,0.04)",
    "font_color": "#64748b",
    
    "colorscale_extended": [
      "#c5a059", "#b87333", "#1e1b4b", "#0f172a", 
      "#10b981", "#be123c", "#f59e0b", "#d5b472",
      "#8b5cf6", "#c28042", "#64748b", "#f4f1ea"
    ],

    "severity": {
      "critical": "#be123c",
      "warning":  "#b87333",
      "normal":   "#1e1b4b",
      "stale":    "#94a3b8"
    },

    "plotly": {
      "bg":      "transparent",
      "plot_bg": "transparent"
    },

    "echarts": {
      "tooltip_bg":       "rgba(255,255,255,0.96)",
      "tooltip_border":   "rgba(197,160,89,0.3)",
      "tooltip_text":     "#1e1b4b",
      "axis_line_color":  "rgba(30,27,75,0.1)",
      "axis_label_color": "rgba(30,27,75,0.6)",
      "split_line_color": "rgba(30,27,75,0.04)",
      "glow_blur":        10,
      "area_opacity_top": 0.28,
      "area_opacity_base":0.02
    }
  }
}