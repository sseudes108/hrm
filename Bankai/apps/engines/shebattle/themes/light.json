{
  "meta": {
    "name": "SheBattle Light - Barbie Hyper-Glow",
    "base": "light",
    "description": "Tema claro extravagante com rosa neon, azul ciano e branco luxuoso com acabamento em acrílico polido de alta reflexão."
  },

  "layout": {
    "header_height": "72px",
    "icon_size": "42px"
  },

  "icons": {
    "toggle": "lightbulb-off"
  },

  "colors": {
    "background":     "#f7f4ff",
    "surface":        "#ffffff",
    "surface_2":      "#f0ecf7",

    "primary":        "#ff2e9e",
    "primary_hover":  "#ff5bb5",

    "secondary":      "#00cfe8",
    "accent":         "#24163a",

    "text":           "#24163a",
    "text_muted":     "#6d5c91",
    "text_disabled":  "#b6a7cf",

    "border":         "#dccdf7",
    "border_focus":   "#ff2e9e",

    "success":        "#00cfe8",
    "warning":        "#ff9e2e",
    "danger":         "#ff3366",
    "info":           "#9b5de5"
  },

  "typography": {
    "font_family":      "Inter, system-ui, sans-serif",
    "font_family_mono": "JetBrains Mono, monospace",
    "size_xs":          10,
    "size_sm":          12,
    "size_base":        14,
    "size_subtitle":    17,
    "size_title":       25,
    "size_display":     42,
    "weight_normal":    400,
    "weight_medium":    500,
    "weight_bold":      700,
    "line_height":      1.65
  },

  "effects": {
    "hover_y": "-4px",
    "backdrop_blur": "12px",
    
    "glow_primary": "0 0 18px rgba(255,46,158,0.28)",
    "glow_danger":  "0 0 14px rgba(255,51,102,0.22)",
    
    "gradient_primary": "linear-gradient(135deg, #ff2e9e 0%, #00cfe8 100%)",
    "gradient_surface": "linear-gradient(180deg, rgba(255,255,255,0.85) 0%, rgba(240,236,247,0.95) 100%)",
    
    "surface_overlay": {
      "enabled": true,
      "border_gradient": "linear-gradient(135deg, rgba(255,46,158,0.3) 0%, rgba(220,205,247,0.5) 50%, rgba(0,207,232,0.25) 100%)",
      "inner_shadow": "inset 0 1px 0px rgba(255,255,255,0.9), inset 0 -1px 12px rgba(36,22,58,0.02)"
    }
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "14px",
    "lg": "24px",
    "xl": "42px"
  },

  "borders": {
    "width":       "1px",
    "radius_sm":   "4px",
    "radius_md":   "8px",
    "radius_lg":   "16px",
    "radius_full": "9999px",
    "shadow_sm":   "0 2px 10px rgba(255,46,158,0.10)",
    "shadow_md":   "0 8px 28px rgba(0,240,255,0.12)",
    "shadow_lg":   "0 14px 48px rgba(255,46,158,0.16)"
  },

  "chart": {
    "height": 420,
    "grid_color": "rgba(36,22,58,0.08)",
    "font_color": "#4c3a70",
    
    "colorscale_extended": [
      "#ff2e9e", "#00cfe8", "#9b5de5", "#24163a",
      "#ff5bb5", "#00bbf9", "#f15bb5", "#ff9e2e",
      "#ff8ac2", "#4cc9f0", "#7209b7", "#f72585"
    ],

    "severity": {
      "critical": "#ff3366",
      "warning":  "#ff9e2e",
      "normal":   "#00cfe8",
      "stale":    "#b6a7cf"
    },

    "plotly": {
      "bg":      "transparent",
      "plot_bg": "transparent"
    },

    "echarts": {
      "tooltip_bg":       "rgba(255,255,255,0.96)",
      "tooltip_border":   "rgba(255,46,158,0.25)",
      "tooltip_text":     "#24163a",
      "axis_line_color":  "rgba(0,207,232,0.22)",
      "axis_label_color": "rgba(36,22,58,0.55)",
      "split_line_color": "rgba(255,46,158,0.08)",
      "glow_blur":        8,
      "area_opacity_top": 0.35,
      "area_opacity_base":0.04
    }
  }
}